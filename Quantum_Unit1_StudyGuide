    <div class="code-block" style="margin-top:2rem">
      <span class="lang-tag">Python / Qiskit</span>
      <code><span class="cm"># Install: pip install qiskit qiskit-aer</span>
<span class="kw">from</span> qiskit <span class="kw">import</span> QuantumCircuit

<span class="cm"># Create a 2-qubit circuit</span>
qc = QuantumCircuit(<span class="num">2</span>, <span class="num">2</span>)

<span class="cm"># Hadamard on qubit 0 → puts it in superposition |+⟩</span>
qc.<span class="fn">h</span>(<span class="num">0</span>)

<span class="cm"># CNOT (controlled-X) on qubit 1, controlled by qubit 0</span>
<span class="cm"># Creates a Bell state: (|00⟩ + |11⟩) / √2</span>
qc.<span class="fn">cx</span>(<span class="num">0</span>, <span class="num">1</span>)

<span class="cm"># Measure both qubits</span>
qc.<span class="fn">measure</span>([<span class="num">0</span>, <span class="num">1</span>], [<span class="num">0</span>, <span class="num">1</span>])

<span class="cm"># Draw the circuit</span>
<span class="fn">print</span>(qc.<span class="fn">draw</span>())

<span class="cm"># Simulate with Aer</span>
<span class="kw">from</span> qiskit_aer <span class="kw">import</span> AerSimulator
sim = AerSimulator()
job = sim.<span class="fn">run</span>(qc, shots=<span class="num">1024</span>)
counts = job.<span class="fn">result</span>().<span class="fn">get_counts</span>()
<span class="fn">print</span>(counts)  <span class="cm"># {'00': ~512, '11': ~512} — Bell state confirmed!</span></code>
    </div>
