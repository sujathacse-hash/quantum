<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quantum Computing — Unit I: Fundamentals</title>
<style>
  /* ── Tokens ─────────────────────────────────────────── */
  :root {
    --ink:      #0f172a;
    --ink2:     #334155;
    --ink3:     #64748b;
    --page:     #f8faff;
    --surface:  #ffffff;
    --surface2: #f1f5ff;
    --q-blue:   #3b5bdb;
    --q-indigo: #4c6ef5;
    --q-purple: #7048e8;
    --q-teal:   #0ca678;
    --q-coral:  #f76707;
    --q-gold:   #e67700;
    --q-navy:   #1c3770;
    --border:   #dce4f5;
    --radius:   12px;
    --font-display: 'Georgia', 'Times New Roman', serif;
    --font-body:    system-ui, -apple-system, 'Segoe UI', sans-serif;
    --font-mono:    'Courier New', Courier, monospace;
  }

  /* ── Reset ───────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    background: var(--page);
    color: var(--ink);
    line-height: 1.7;
    font-size: 16px;
  }

  /* ── Progress bar ────────────────────────────────────── */
  #progress-bar {
    position: fixed; top: 0; left: 0; height: 3px;
    background: linear-gradient(90deg, var(--q-blue), var(--q-purple));
    width: 0%; z-index: 1000;
    transition: width 0.1s;
  }

  /* ── Nav ─────────────────────────────────────────────── */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 56px;
  }
  .nav-brand {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--font-display);
    font-size: 1.05rem; font-weight: 700;
    color: var(--q-navy); text-decoration: none;
  }
  .nav-brand .atom { font-size: 1.4rem; }
  .nav-links {
    display: flex; gap: 0; list-style: none;
  }
  .nav-links a {
    display: block; padding: 6px 12px; border-radius: 6px;
    font-size: 0.82rem; font-weight: 500; color: var(--ink2);
    text-decoration: none; transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .nav-links a:hover { background: var(--surface2); color: var(--q-blue); }
  .nav-links a.active { background: var(--surface2); color: var(--q-blue); }

  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    position: relative; overflow: hidden;
    background: linear-gradient(135deg, #e8f0fe 0%, #f3effe 50%, #e6f9f2 100%);
    padding: 5rem 2rem 4rem;
    text-align: center;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: 
      radial-gradient(circle at 15% 50%, rgba(59,91,219,0.12) 0%, transparent 55%),
      radial-gradient(circle at 85% 30%, rgba(112,72,232,0.10) 0%, transparent 55%);
  }
  .hero-eyebrow {
    display: inline-block; margin-bottom: 1rem;
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--q-blue);
    background: rgba(59,91,219,0.1); border: 1px solid rgba(59,91,219,0.25);
    padding: 4px 14px; border-radius: 999px;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    color: var(--q-navy); line-height: 1.15;
    margin-bottom: 1rem; position: relative;
  }
  .hero h1 em {
    font-style: normal; color: var(--q-blue);
  }
  .hero-sub {
    font-size: 1.1rem; color: var(--ink2); max-width: 560px;
    margin: 0 auto 2rem; position: relative;
  }
  .hero-tags {
    display: flex; flex-wrap: wrap; gap: 8px;
    justify-content: center; position: relative;
    margin-bottom: 2.5rem;
  }
  .tag {
    font-size: 0.78rem; font-weight: 600; padding: 4px 12px;
    border-radius: 999px; border: 1.5px solid;
    cursor: default;
  }
  .tag-blue { color: var(--q-blue); border-color: rgba(59,91,219,0.35); background: rgba(59,91,219,0.07); }
  .tag-purple { color: var(--q-purple); border-color: rgba(112,72,232,0.35); background: rgba(112,72,232,0.07); }
  .tag-teal { color: var(--q-teal); border-color: rgba(12,166,120,0.35); background: rgba(12,166,120,0.07); }
  .tag-coral { color: var(--q-coral); border-color: rgba(247,103,7,0.35); background: rgba(247,103,7,0.07); }
  .hero-meta {
    display: flex; justify-content: center; gap: 2rem;
    font-size: 0.85rem; color: var(--ink3); position: relative;
  }
  .hero-meta span { display: flex; align-items: center; gap: 6px; }

  /* ── Layout ──────────────────────────────────────────── */
  .wrapper {
    max-width: 1100px; margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Sections ────────────────────────────────────────── */
  .section {
    padding: 4rem 0;
    border-bottom: 1px solid var(--border);
  }
  .section:last-child { border-bottom: none; }
  .section-header {
    display: flex; align-items: flex-start; gap: 1.2rem;
    margin-bottom: 2rem;
  }
  .section-icon {
    width: 48px; height: 48px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; flex-shrink: 0;
  }
  .section-header-text {}
  .section-eyebrow {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; margin-bottom: 4px;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: 1.85rem; color: var(--q-navy); line-height: 1.2;
  }
  .section-intro {
    font-size: 1.05rem; color: var(--ink2); margin-bottom: 2rem;
    max-width: 720px; border-left: 3px solid var(--border);
    padding-left: 1rem;
  }

  /* ── Cards ───────────────────────────────────────────── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }
  .card-grid-2 { grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); }
  .card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.5rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .card:hover {
    box-shadow: 0 8px 24px rgba(59,91,219,0.10);
    transform: translateY(-2px);
  }
  .card-accent { border-top: 3px solid; }
  .card-blue { border-top-color: var(--q-blue); }
  .card-purple { border-top-color: var(--q-purple); }
  .card-teal { border-top-color: var(--q-teal); }
  .card-coral { border-top-color: var(--q-coral); }
  .card h3 {
    font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem;
    display: flex; align-items: center; gap: 8px;
  }
  .card p { font-size: 0.92rem; color: var(--ink2); line-height: 1.65; }

  /* ── Callout ─────────────────────────────────────────── */
  .callout {
    border-radius: var(--radius); padding: 1.25rem 1.5rem;
    margin: 1.5rem 0; display: flex; gap: 1rem; align-items: flex-start;
    font-size: 0.93rem;
  }
  .callout-blue { background: rgba(59,91,219,0.07); border: 1px solid rgba(59,91,219,0.2); }
  .callout-teal { background: rgba(12,166,120,0.07); border: 1px solid rgba(12,166,120,0.2); }
  .callout-coral { background: rgba(247,103,7,0.07); border: 1px solid rgba(247,103,7,0.2); }
  .callout-purple { background: rgba(112,72,232,0.07); border: 1px solid rgba(112,72,232,0.2); }
  .callout-icon { font-size: 1.3rem; line-height: 1; flex-shrink: 0; margin-top: 2px; }
  .callout strong { display: block; margin-bottom: 3px; }

  /* ── Formula box ─────────────────────────────────────── */
  .formula-box {
    background: var(--q-navy); color: #e2e8f0;
    border-radius: var(--radius); padding: 1.5rem 2rem;
    font-family: var(--font-mono); margin: 1.5rem 0;
    overflow-x: auto;
  }
  .formula-box .main-eq {
    font-size: 1.5rem; color: #93c5fd;
    text-align: center; margin-bottom: 0.75rem;
    display: block;
  }
  .formula-box .sub-eq {
    font-size: 1rem; color: #86efac;
    text-align: center; display: block;
    margin-bottom: 0.5rem;
  }
  .formula-box .note {
    font-size: 0.82rem; color: #94a3b8;
    text-align: center; font-family: var(--font-body);
    font-style: italic;
  }

  /* ── Bloch sphere SVG ────────────────────────────────── */
  .bloch-wrapper {
    display: flex; align-items: flex-start; gap: 2rem;
    flex-wrap: wrap;
  }
  .bloch-svg-container {
    flex: 0 0 260px;
  }
  .bloch-svg-container svg { width: 100%; height: auto; }
  .bloch-legend { flex: 1; min-width: 240px; }
  .bloch-legend-item {
    display: flex; gap: 10px; align-items: flex-start;
    padding: 0.6rem 0; border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .bloch-legend-item:last-child { border-bottom: none; }
  .bloch-dot {
    width: 12px; height: 12px; border-radius: 50%;
    flex-shrink: 0; margin-top: 4px;
  }
  .bloch-legend-item strong { color: var(--ink); }
  .bloch-legend-item span { color: var(--ink2); }

  /* ── Comparison table ────────────────────────────────── */
  .compare-table {
    width: 100%; border-collapse: collapse;
    border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .compare-table th {
    padding: 0.85rem 1.2rem; text-align: left;
    font-size: 0.82rem; font-weight: 700; letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .compare-table th:first-child { background: var(--q-navy); color: white; }
  .compare-table th.th-classic { background: #fff0ec; color: var(--q-coral); }
  .compare-table th.th-quantum { background: #e6f9f2; color: var(--q-teal); }
  .compare-table td { padding: 0.75rem 1.2rem; vertical-align: top; }
  .compare-table tr:nth-child(even) td { background: var(--surface2); }
  .compare-table tr:nth-child(odd) td { background: var(--surface); }
  .compare-table td:first-child { font-weight: 600; color: var(--q-navy); }
  .compare-table td:nth-child(3) { color: var(--q-teal); }

  /* ── Dirac table ─────────────────────────────────────── */
  .dirac-table {
    width: 100%; border-collapse: collapse;
    font-size: 0.9rem; border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--border);
  }
  .dirac-table th {
    background: var(--q-navy); color: white;
    padding: 0.7rem 1.2rem; text-align: left;
    font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .dirac-table td { padding: 0.7rem 1.2rem; vertical-align: middle; }
  .dirac-table tr:nth-child(even) td { background: var(--surface2); }
  .dirac-table tr:nth-child(odd) td { background: var(--surface); }
  .dirac-sym {
    font-family: var(--font-mono); font-size: 1.1rem;
    font-weight: 700;
  }

  /* ── Hardware grid ───────────────────────────────────── */
  .hw-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.25rem 1.4rem;
    transition: box-shadow 0.2s;
  }
  .hw-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
  .hw-card-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 0.6rem;
  }
  .hw-card h3 { font-size: 1rem; font-weight: 700; }
  .hw-temp {
    font-size: 0.75rem; font-weight: 600; padding: 3px 9px;
    border-radius: 999px; background: var(--surface2);
    color: var(--ink3); white-space: nowrap;
  }
  .hw-company { font-size: 0.8rem; color: var(--ink3); margin-bottom: 0.6rem; }
  .hw-card p { font-size: 0.88rem; color: var(--ink2); line-height: 1.6; }

  /* ── Code block ──────────────────────────────────────── */
  .code-block {
    background: #0f172a; border-radius: var(--radius);
    padding: 1.5rem; overflow-x: auto; margin: 1.5rem 0;
    position: relative;
  }
  .code-block .lang-tag {
    position: absolute; top: 10px; right: 12px;
    font-size: 0.7rem; font-weight: 600; color: #475569;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .code-block code {
    font-family: var(--font-mono); font-size: 0.88rem;
    line-height: 1.9; color: #e2e8f0;
  }
  .code-block .kw  { color: #93c5fd; }  /* keywords */
  .code-block .fn  { color: #86efac; }  /* functions */
  .code-block .str { color: #fca5a5; }  /* strings */
  .code-block .cm  { color: #64748b; }  /* comments */
  .code-block .num { color: #fcd34d; }  /* numbers */
  .code-block .op  { color: #c084fc; }  /* operators */

  /* ── Interactive Quiz ────────────────────────────────── */
  .quiz-section {
    background: linear-gradient(135deg, #f3effe 0%, #e8f0fe 100%);
    border-radius: 16px; padding: 2.5rem; margin: 2rem 0;
  }
  .quiz-section h3 {
    font-family: var(--font-display); font-size: 1.4rem;
    color: var(--q-navy); margin-bottom: 0.3rem;
  }
  .quiz-section p.quiz-sub { color: var(--ink2); font-size: 0.9rem; margin-bottom: 1.5rem; }
  .quiz-q { margin-bottom: 1.5rem; }
  .quiz-q .q-text {
    font-weight: 600; color: var(--ink); margin-bottom: 0.75rem;
    font-size: 0.95rem;
  }
  .quiz-options { display: flex; flex-direction: column; gap: 8px; }
  .quiz-opt {
    display: flex; align-items: center; gap: 10px;
    padding: 0.7rem 1rem; background: white; border: 1.5px solid var(--border);
    border-radius: 8px; cursor: pointer; font-size: 0.9rem;
    transition: border-color 0.15s, background 0.15s;
    user-select: none;
  }
  .quiz-opt:hover { border-color: var(--q-blue); background: rgba(59,91,219,0.04); }
  .quiz-opt.correct { border-color: var(--q-teal); background: rgba(12,166,120,0.08); color: var(--q-teal); font-weight: 600; }
  .quiz-opt.wrong   { border-color: var(--q-coral); background: rgba(247,103,7,0.08); color: var(--q-coral); font-weight: 600; }
  .quiz-opt.disabled { pointer-events: none; }
  .quiz-opt .opt-letter {
    width: 24px; height: 24px; border-radius: 50%;
    background: var(--surface2); display: flex; align-items: center;
    justify-content: center; font-size: 0.75rem; font-weight: 700;
    flex-shrink: 0; color: var(--ink3);
  }
  .quiz-opt.correct .opt-letter { background: var(--q-teal); color: white; }
  .quiz-opt.wrong .opt-letter   { background: var(--q-coral); color: white; }
  .quiz-feedback {
    display: none; margin-top: 8px; padding: 8px 12px;
    border-radius: 6px; font-size: 0.85rem; font-weight: 500;
  }
  .quiz-feedback.show { display: block; }
  .quiz-feedback.fb-ok  { background: rgba(12,166,120,0.1); color: var(--q-teal); }
  .quiz-feedback.fb-err { background: rgba(247,103,7,0.1); color: var(--q-coral); }
  .quiz-score {
    text-align: center; padding: 1rem;
    font-size: 1.1rem; font-weight: 700; color: var(--q-navy);
    display: none;
  }
  #quiz-btn {
    display: block; margin: 0 auto; padding: 0.7rem 2rem;
    background: var(--q-blue); color: white; border: none;
    border-radius: 8px; font-size: 0.95rem; font-weight: 600;
    cursor: pointer; transition: background 0.15s;
  }
  #quiz-btn:hover { background: var(--q-navy); }

  /* ── Superposition visual ────────────────────────────── */
  .qubit-demo {
    display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.5rem; margin: 1.5rem 0;
  }
  .qubit-circle {
    width: 90px; height: 90px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 1.3rem; font-weight: 700;
    flex-shrink: 0;
  }
  .qubit-bit  { background: #fff0ec; color: var(--q-coral); border: 2px solid rgba(247,103,7,0.3); }
  .qubit-qbit { background: var(--surface2); color: var(--q-blue); border: 2px dashed var(--q-blue);
                animation: spin-fade 3s ease-in-out infinite; }
  @keyframes spin-fade {
    0%,100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.95); }
  }
  .qubit-info h4 { font-size: 0.95rem; font-weight: 700; margin-bottom: 4px; }
  .qubit-info p  { font-size: 0.85rem; color: var(--ink2); }

  /* ── Entanglement visual ─────────────────────────────── */
  .entangle-pair {
    display: flex; align-items: center; justify-content: center;
    gap: 0; margin: 1.5rem 0;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.5rem;
  }
  .e-qubit {
    width: 70px; height: 70px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 1.1rem; font-weight: 700;
    background: rgba(112,72,232,0.1); color: var(--q-purple);
    border: 2px solid rgba(112,72,232,0.3);
  }
  .e-link {
    flex: 1; height: 2px; max-width: 120px;
    background: linear-gradient(90deg, var(--q-purple), var(--q-blue));
    position: relative;
  }
  .e-link::after {
    content: '⟺'; position: absolute; top: -14px;
    left: 50%; transform: translateX(-50%);
    font-size: 1rem; color: var(--q-purple);
  }
  .e-label { text-align: center; font-size: 0.8rem; color: var(--ink3); margin-top: 6px; }

  /* ── Platform cards ──────────────────────────────────── */
  .platform-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
  .platform-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.2rem;
    transition: box-shadow 0.2s;
  }
  .platform-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .platform-card.featured { border-width: 2px; border-color: var(--q-blue); }
  .platform-name { font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
  .platform-by   { font-size: 0.78rem; color: var(--ink3); margin-bottom: 0.6rem; }
  .platform-card p { font-size: 0.85rem; color: var(--ink2); line-height: 1.6; }
  .platform-badge {
    display: inline-block; font-size: 0.7rem; font-weight: 700;
    padding: 2px 8px; border-radius: 999px; margin-bottom: 6px;
    background: rgba(59,91,219,0.1); color: var(--q-blue);
  }

  /* ── Learning outcomes ───────────────────────────────── */
  .lo-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .lo-item {
    display: flex; gap: 12px; align-items: flex-start;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1rem 1.2rem;
  }
  .lo-num {
    width: 32px; height: 32px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem; font-weight: 700; flex-shrink: 0;
    color: white;
  }
  .lo-item h4 { font-size: 0.95rem; font-weight: 700; margin-bottom: 2px; }
  .lo-item p  { font-size: 0.87rem; color: var(--ink2); }

  /* ── Footer ──────────────────────────────────────────── */
  footer {
    background: var(--q-navy); color: rgba(255,255,255,0.7);
    padding: 2.5rem 2rem; text-align: center; font-size: 0.85rem;
  }
  footer strong { color: white; }
  footer a { color: rgba(255,255,255,0.7); }

  /* ── Scroll reveal ───────────────────────────────────── */
  .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.55s, transform 0.55s; }
  .reveal.visible { opacity: 1; transform: none; }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 700px) {
    nav { padding: 0 1rem; }
    .nav-links { display: none; }
    .hero { padding: 3rem 1rem 2.5rem; }
    .wrapper { padding: 0 1rem; }
    .bloch-wrapper { flex-direction: column; }
    .bloch-svg-container { flex: 0 0 auto; width: 220px; margin: 0 auto; }
    .card-grid-2 { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .qubit-qbit { animation: none; }
    .reveal { opacity: 1; transform: none; transition: none; }
    html { scroll-behavior: auto; }
  }
</style>
</head>
