    <div class="platform-grid">
      <div class="platform-card featured">
        <div class="platform-badge">Course Platform</div>
        <div class="platform-name" style="color:var(--q-blue)">⬡ Qiskit</div>
        <div class="platform-by">by IBM · Open Source · Python</div>
