<script>
// ── Progress bar ──────────────────────────────────────────
window.addEventListener('scroll', () => {
  const doc = document.documentElement;
  const scrolled = doc.scrollTop / (doc.scrollHeight - doc.clientHeight);
  document.getElementById('progress-bar').style.width = (scrolled * 100) + '%';
});

// ── Scroll reveal ─────────────────────────────────────────
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ── Active nav ────────────────────────────────────────────
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav-links a');
window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(sec => {
    if (window.scrollY >= sec.offsetTop - 80) current = sec.id;
  });
  navLinks.forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + current);
  });
}, { passive: true });

// ── Quiz ──────────────────────────────────────────────────
const answers = {};
const correctFeedback = {
  q1: 'Correct! |α|² and |β|² are probabilities. Since qubits must produce some outcome when measured, they must sum to 1. This is the Born rule.',
  q2: 'Correct! The north pole (θ=0) represents |0⟩. The south pole (θ=π) represents |1⟩. All other points are superpositions.',
  q3: 'Correct! The Bell state is the canonical example of maximal entanglement. Neither qubit has a definite state alone — only the pair does.',
  q4: 'Correct! The bra ⟨ψ| is the conjugate transpose (Hermitian adjoint, denoted ψ†). For real vectors it\'s just the transpose.',
  q5: 'Correct! Qiskit is IBM\'s open-source Python SDK and the primary tool for this course. Install with: pip install qiskit',
};
const wrongFeedback = {
  q1: 'Not quite. The normalization condition ensures total measurement probability = 1. α and β are complex amplitudes, and both don\'t need to be equal.',
  q2: 'Not quite. The north pole represents |0⟩. The south pole is |1⟩. The equator contains equal superposition states like |+⟩.',
  q3: 'Not quite. The Bell state is an entangled state. When you measure A, it collapses both qubits instantaneously — that\'s the defining property of entanglement.',
  q4: 'Not quite. The bra ⟨ψ| is the conjugate transpose, not just the conjugate. For a column vector [α,β]ᵀ, the bra is the row vector [α*,β*].',
  q5: 'Not quite. Cirq is Google\'s framework, PennyLane is by Xanadu (quantum ML focus), and Q# is Microsoft\'s language. Qiskit is IBM\'s platform used in this course.',
};

function checkAnswer(el, qId, chosen, correct) {
  const container = document.getElementById(qId);
  if (container.dataset.answered) return;
  container.dataset.answered = 'true';
  answers[qId] = chosen === correct;

  const opts = container.querySelectorAll('.quiz-opt');
  const letters = ['A','B','C','D'];
  opts.forEach((opt, i) => {
    opt.classList.add('disabled');
    if (letters[i] === correct) opt.classList.add('correct');
    else if (opt === el && chosen !== correct) opt.classList.add('wrong');
  });

  const fb = document.getElementById('fb-' + qId);
  fb.classList.add('show');
  if (chosen === correct) {
    fb.classList.add('fb-ok');
    fb.textContent = '✓ ' + correctFeedback[qId];
  } else {
    fb.classList.add('fb-err');
    fb.textContent = '✗ ' + wrongFeedback[qId];
  }
}

function showScore() {
  const score = Object.values(answers).filter(Boolean).length;
  const total = 5;
  const scoreEl = document.getElementById('quiz-score');
  const msg = score === 5 ? '🎉 Perfect! You\'ve mastered Unit I fundamentals.' :
               score >= 3 ? '👍 Good work! Review the topics you missed.' :
               '📖 Keep studying — revisit the sections above.';
  scoreEl.innerHTML = `You scored <strong>${score} / ${total}</strong> — ${msg}`;
  scoreEl.style.display = 'block';
  document.getElementById('quiz-btn').style.display = 'none';
}
